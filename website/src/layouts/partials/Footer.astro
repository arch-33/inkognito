---
import config from "@/config/config.json";
import menu from "@/config/menu.json";
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import logoImg from "../../../public/images/logo.png";
const { footer } = menu;
const { copyright, footer_description } = config.params;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const withBase = (url: string) => url.startsWith("http") ? url : `${base}/${url}`;
---

<footer class="border-t border-border">
  <div class="container mx-auto px-4 py-16">
    <div class="flex flex-col md:flex-row items-center md:items-start justify-between gap-10">
      <div class="text-center md:text-left max-w-sm">
        <a href={withBase("")} class="inline-flex items-center gap-2 mb-3">
          <Image src={logoImg} alt="Inkognito" class="w-7 h-7" width={28} height={28} />
          <span class="text-lg font-bold text-text">Inkognito</span>
        </a>
        <p class="text-sm text-text-disabled leading-relaxed">{footer_description}</p>
      </div>

      <div class="flex items-center gap-8">
        {footer.map((item) => (
          <a
            class="text-sm text-text-disabled hover:text-text transition-colors duration-200"
            href={withBase(item.url)}
            target={item.url.startsWith('http') ? '_blank' : undefined}
            rel={item.url.startsWith('http') ? 'noopener' : undefined}
          >
            {item.name}
          </a>
        ))}
      </div>
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-between mt-12 pt-8 border-t border-border gap-4">
      <p class="text-xs text-text-disabled" set:html={markdownify(copyright)} />
      <div class="flex items-center gap-4">
        <a href="https://github.com/arch-33/inkognito" target="_blank" rel="noopener" class="text-text-disabled hover:text-text-secondary transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
