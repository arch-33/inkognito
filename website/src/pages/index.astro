---
import Base from "@/layouts/Base.astro";
import { Image } from "astro:assets";
import screenshotEdit from "../../public/images/screenshot-edit-mode.png";
import screenshotPreview from "../../public/images/screenshot-preview-mode.png";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title="Inkognito – Your thoughts deserve privacy" description="A private, local-first markdown notepad with screen capture protection. Built with Tauri 2 for macOS, Windows, and Linux.">

  <!-- Hero -->
  <section class="relative min-h-[100vh] flex items-center justify-center overflow-hidden">
    <!-- Aurora gradient background -->
    <div class="aurora-bg"></div>
    <!-- Grid overlay -->
    <div class="grid-overlay"></div>

    <div class="relative z-10 container mx-auto px-4 pt-24 pb-16">
      <div class="text-center max-w-4xl mx-auto">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-black/10 dark:border-white/10 bg-black/5 dark:bg-white/5 backdrop-blur-sm mb-8 animate-fade-in">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          <span class="text-sm text-text-secondary">Free & open-source</span>
        </div>

        <!-- Headline -->
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold tracking-tight leading-[1.05] mb-6 animate-fade-in" style="animation-delay: 0.1s">
          <span class="text-text">Your thoughts</span><br>
          <span class="hero-gradient-text">deserve privacy.</span>
        </h1>

        <!-- Subheading -->
        <p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-in" style="animation-delay: 0.2s">
          A beautiful, local-first markdown notepad that keeps your writing
          invisible to prying eyes. No cloud. No accounts. No telemetry.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 justify-center mb-6 animate-fade-in" style="animation-delay: 0.3s">
          <a href={`${base}/download`} class="group relative inline-flex items-center gap-2 px-8 py-3.5 rounded-full bg-black dark:bg-white text-white dark:text-black font-semibold text-base transition-all duration-300 hover:shadow-[0_0_40px_rgba(129,140,248,0.4)] hover:scale-105">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download for free
          </a>
          <a href="https://github.com/arch-33/inkognito" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full border border-black/20 dark:border-white/20 text-text font-medium text-base transition-all duration-300 hover:bg-black/5 dark:hover:bg-white/10 hover:border-black/30 dark:hover:border-white/30">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
        </div>

        <p class="text-sm text-text-disabled animate-fade-in" style="animation-delay: 0.4s">
          Available for macOS, Windows & Linux
        </p>
      </div>

      <!-- Floating App Screenshot -->
      <div class="relative mt-16 max-w-5xl mx-auto animate-fade-in" style="animation-delay: 0.5s">
        <div class="screenshot-wrapper">
          <!-- Glow behind screenshot -->
          <div class="absolute -inset-4 bg-gradient-to-r from-indigo-500/20 via-purple-500/20 to-indigo-500/20 rounded-3xl blur-3xl"></div>
          <div class="relative rounded-2xl overflow-hidden border border-border shadow-2xl shadow-indigo-500/10">
            <Image
              src={screenshotPreview}
              alt="Inkognito preview mode"
              class="w-full"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-32 hero-bottom-fade z-10"></div>
  </section>

  <!-- Screenshot Showcase (Edit vs Preview) -->
  <section class="relative py-24 md:py-32 overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-text mb-4 tracking-tight">
          Write in markdown.<br>
          <span class="text-text-disabled">See it come alive.</span>
        </h2>
        <p class="text-text-secondary max-w-xl mx-auto text-lg">
          A powerful CodeMirror 6 editor with syntax highlighting on the left,
          beautiful rendered preview on the right.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-6xl mx-auto">
        <!-- Edit Mode -->
        <div class="group relative">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-indigo-500/50 to-purple-500/50 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-sm"></div>
          <div class="relative rounded-2xl overflow-hidden border border-border bg-surface">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-black/5 dark:border-white/5 bg-black/5 dark:bg-white/5">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
              </div>
              <span class="text-xs text-text-disabled ml-2">Edit Mode</span>
            </div>
            <Image src={screenshotEdit} alt="Inkognito edit mode – markdown editor with syntax highlighting" class="w-full" loading="lazy" />
          </div>
        </div>

        <!-- Preview Mode -->
        <div class="group relative">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-purple-500/50 to-pink-500/50 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-sm"></div>
          <div class="relative rounded-2xl overflow-hidden border border-border bg-surface">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-black/5 dark:border-white/5 bg-black/5 dark:bg-white/5">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
              </div>
              <span class="text-xs text-text-disabled ml-2">Preview Mode</span>
            </div>
            <Image src={screenshotPreview} alt="Inkognito preview mode – rendered markdown with rich formatting" class="w-full" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bento Features Grid -->
  <section class="relative py-24 md:py-32">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <p class="text-primary font-semibold text-sm uppercase tracking-widest mb-3">Features</p>
        <h2 class="text-3xl md:text-5xl font-bold text-text tracking-tight">
          Built for the privacy-conscious
        </h2>
      </div>

      <div class="bento-grid max-w-6xl mx-auto">
        <!-- Large card: Content Protection -->
        <div class="bento-card bento-card-lg group">
          <div class="bento-card-inner">
            <div class="flex items-start justify-between mb-6">
              <div class="w-12 h-12 rounded-xl bg-red-500/10 border border-red-500/20 flex items-center justify-center">
                <svg class="w-6 h-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
                </svg>
              </div>
              <span class="text-xs text-text-disabled font-mono">01</span>
            </div>
            <h3 class="text-xl font-semibold text-text mb-3">Screen Capture Protection</h3>
            <p class="text-text-secondary leading-relaxed">
              One click hides your notes from screen capture, recordings, and screen sharing.
              Your content becomes invisible in screenshots and video calls – truly private writing.
            </p>
            <div class="mt-6 flex gap-2">
              <span class="text-xs px-2.5 py-1 rounded-full bg-black/5 dark:bg-white/5 border border-border text-text-secondary">macOS</span>
              <span class="text-xs px-2.5 py-1 rounded-full bg-black/5 dark:bg-white/5 border border-border text-text-secondary">Windows</span>
            </div>
          </div>
        </div>

        <!-- Medium card: 100% Local -->
        <div class="bento-card group">
          <div class="bento-card-inner">
            <div class="w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-text mb-2">100% Local</h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              All data lives on your machine. No cloud sync, no accounts, no telemetry. Fast, reliable, and fully portable.
            </p>
          </div>
        </div>

        <!-- Medium card: Markdown Editor -->
        <div class="bento-card group">
          <div class="bento-card-inner">
            <div class="w-12 h-12 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-text mb-2">Markdown Editor</h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              Powered by CodeMirror 6 with syntax highlighting, live preview, Mermaid diagrams, and customizable fonts.
            </p>
          </div>
        </div>

        <!-- Medium card: Daily Notes -->
        <div class="bento-card group">
          <div class="bento-card-inner">
            <div class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-text mb-2">Daily Notes</h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              One note per day with a mini calendar. Perfect for journaling, daily logs, or capturing fleeting thoughts.
            </p>
          </div>
        </div>

        <!-- Large card: Cross-Platform -->
        <div class="bento-card bento-card-lg group">
          <div class="bento-card-inner">
            <div class="flex items-start justify-between mb-6">
              <div class="w-12 h-12 rounded-xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center">
                <svg class="w-6 h-6 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z" />
                </svg>
              </div>
              <span class="text-xs text-text-disabled font-mono">06</span>
            </div>
            <h3 class="text-xl font-semibold text-text mb-3">Cross-Platform Native</h3>
            <p class="text-text-secondary leading-relaxed">
              Built with Tauri 2 and Rust for native performance on macOS, Windows, and Linux.
              Minimal footprint, maximum speed – no Electron bloat.
            </p>
            <div class="mt-6 flex gap-3">
              <svg class="w-6 h-6 text-text-disabled" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              <svg class="w-6 h-6 text-text-disabled" fill="currentColor" viewBox="0 0 24 24"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
              <svg class="w-6 h-6 text-text-disabled" fill="currentColor" viewBox="0 0 24 24"><path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.368 1.884 1.43.868.07 1.662-.33 2.095-.88.46.067 1.045-.049 1.196-.29a.71.71 0 00.072-.4l-.006-.032c-.019-.135-.08-.285-.13-.44-.063-.2-.124-.38-.107-.493.044-.297-.005-.602-.09-.862a1.31 1.31 0 00-.084-.19c.089-.183.147-.377.147-.59 0-.062-.006-.122-.016-.18a.692.692 0 00-.024-.108.521.521 0 00-.04-.1c.077-.178.098-.372.046-.544-.092-.33-.363-.49-.638-.58-.147-.05-.312-.06-.452-.063a1.348 1.348 0 01-.217-.036c-.155-.036-.23-.07-.362-.117-.073-.025-.161-.054-.27-.094l-.005-.001c-.335-.117-.637-.318-.89-.548l-.025-.029a3.38 3.38 0 01-.226-.293c-.052-.07-.096-.13-.134-.181l-.009-.011c-.387-.538-.62-1.168-.628-1.806 0-.011-.002-.024-.003-.034a2.44 2.44 0 00-.004-.093c.006-.185.02-.358.04-.525a4.48 4.48 0 01.122-.638c.18-.735.5-1.33.864-1.874.382-.567.792-1.092 1.098-1.696.298-.584.52-1.262.453-2.11-.048-.629-.242-1.32-.65-2.068C17.58 3.129 15.273 0 12.504 0z"/></svg>
            </div>
          </div>
        </div>

        <!-- Medium card: Dark & Light -->
        <div class="bento-card group">
          <div class="bento-card-inner">
            <div class="w-12 h-12 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-text mb-2">Dark & Light Themes</h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              Automatic system theme detection or manual override. Designed to look beautiful in both modes.
            </p>
          </div>
        </div>

        <!-- Medium card: Tags -->
        <div class="bento-card group">
          <div class="bento-card-inner">
            <div class="w-12 h-12 rounded-xl bg-pink-500/10 border border-pink-500/20 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-text mb-2">Tags & Favorites</h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              Flexible tagging with autocomplete and a favorites system for quick access to notes that matter.
            </p>
          </div>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href={`${base}/features`} class="inline-flex items-center gap-2 text-primary hover:text-secondary font-medium text-sm transition-colors group">
          Explore all features
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Privacy Statement -->
  <section class="relative py-24 md:py-32 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-indigo-950/10 dark:via-indigo-950/20 to-transparent"></div>

    <div class="relative container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-indigo-500/20 to-purple-500/20 border border-indigo-500/20 mb-8">
          <svg class="w-10 h-10 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold text-text mb-6 tracking-tight">
          Privacy isn't a feature.<br>
          <span class="text-text-disabled">It's the architecture.</span>
        </h2>
        <p class="text-lg text-text-secondary max-w-2xl mx-auto mb-12">
          Inkognito doesn't just promise privacy – it's structurally incapable of leaking your data.
          No servers to breach. No sync to intercept. No analytics to profile you.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
          <div class="text-center">
            <div class="text-4xl font-bold text-text mb-1">0</div>
            <div class="text-sm text-text-disabled">Network requests</div>
          </div>
          <div class="text-center">
            <div class="text-4xl font-bold text-text mb-1">0</div>
            <div class="text-sm text-text-disabled">Tracking pixels</div>
          </div>
          <div class="text-center">
            <div class="text-4xl font-bold text-text mb-1">0</div>
            <div class="text-sm text-text-disabled">Third-party deps</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <p class="text-center text-sm text-text-disabled uppercase tracking-widest mb-8">Built with</p>
      <div class="flex flex-wrap justify-center gap-x-8 gap-y-4 max-w-3xl mx-auto">
        <span class="text-text-secondary font-medium text-sm hover:text-text transition-colors">Tauri 2</span>
        <span class="text-text-disabled">·</span>
        <span class="text-text-secondary font-medium text-sm hover:text-text transition-colors">Rust</span>
        <span class="text-text-disabled">·</span>
        <span class="text-text-secondary font-medium text-sm hover:text-text transition-colors">React 19</span>
